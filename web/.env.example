DATABASE_URL=postgres://postgres:postgres@localhost:5432/keepsake
KEEPSAKE_DATA_SOURCE=mock

# Which draft generator backs POST /api/drafts. Independent of
# KEEPSAKE_DATA_SOURCE. Defaults to "mock". Set "openai" to call an
# OpenAI-compatible chat-completions endpoint (any provider that speaks
# `POST /v1/chat/completions` works — OpenAI proper, Anthropic gateway,
# vLLM, Ollama, a local test stub). When "openai", KEEPSAKE_DRAFT_API_KEY
# is REQUIRED; missing/invalid env fails with a 500 misconfigured error
# rather than silently falling back to mock.
KEEPSAKE_DRAFT_SOURCE=mock
# KEEPSAKE_DRAFT_API_KEY=sk-...
# KEEPSAKE_DRAFT_API_BASE=https://api.openai.com/v1
# KEEPSAKE_DRAFT_MODEL=gpt-4o-mini

# Dev-only sample key. Generate your own with: openssl rand -base64 32
DEV_ENCRYPTION_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Dev-only current user used by /api/session, DB owner resolution, and pnpm db:seed:dev.
# DEV_OWNER_ID must be a UUID; email/name must be valid non-secret sample values.
DEV_OWNER_ID=00000000-0000-4000-8000-000000000001
DEV_OWNER_EMAIL=arthur@example.test
DEV_OWNER_NAME=Arthur

# Gmail OAuth. All four are required for both start and callback to leave the
# 501 "not_configured" path. GOOGLE_REDIRECT_URI may be a full URL or the magic
# value "__ORIGIN__/api/oauth/gmail/callback" for local/dev origin binding.
# OAUTH_STATE_SIGNING_SECRET signs the state cookie issued by start and
# verified by callback; rotate to invalidate in-flight grants. Min 32 chars.
# Generate with: openssl rand -base64 48
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=__ORIGIN__/api/oauth/gmail/callback
OAUTH_STATE_SIGNING_SECRET=replace-with-at-least-32-character-secret-XXXXXXXX

# Optional. Override only for tests that need to point at a local fake token
# endpoint. Defaults to https://oauth2.googleapis.com/token.
# GOOGLE_TOKEN_ENDPOINT=http://localhost:3147/token
