DATABASE_URL=postgres://postgres:postgres@localhost:5432/keepsake
KEEPSAKE_DATA_SOURCE=mock

# Which draft generator backs POST /api/drafts. Independent of
# KEEPSAKE_DATA_SOURCE. Defaults to "mock". Set "openai" to call an
# OpenAI-compatible chat-completions endpoint (any provider that speaks
# `POST /v1/chat/completions` works — OpenAI proper, Anthropic gateway,
# vLLM, Ollama, a local test stub). When "openai", KEEPSAKE_DRAFT_API_KEY
# is REQUIRED; missing/invalid env fails with a 500 misconfigured error
# rather than silently falling back to mock.
KEEPSAKE_DRAFT_SOURCE=mock
# KEEPSAKE_DRAFT_API_KEY=sk-...
# KEEPSAKE_DRAFT_API_BASE=https://api.openai.com/v1
# KEEPSAKE_DRAFT_MODEL=gpt-4o-mini

# Dev-only sample key. Generate your own with: openssl rand -base64 32
DEV_ENCRYPTION_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Dev-only current user. Now the FALLBACK identity used when no
# `keepsake_session` cookie is present (see APP_SESSION_SIGNING_SECRET).
# DEV_OWNER_ID must be a UUID; email/name must be valid non-secret sample values.
DEV_OWNER_ID=00000000-0000-4000-8000-000000000001
DEV_OWNER_EMAIL=arthur@example.test
DEV_OWNER_NAME=Arthur

# App session cookie secret. HMAC-SHA256 over the cookie payload.
# Required when ANY request carries a `keepsake_session` cookie (so any
# environment that's used `POST /api/auth/dev-session/start` to mint
# one needs this set). Min 32 chars. Distinct from OAUTH_STATE_SIGNING_SECRET.
# Generate with: openssl rand -base64 48
APP_SESSION_SIGNING_SECRET=replace-with-at-least-32-character-secret-YYYYYYYY

# Dev-only: gate for the `/api/auth/dev-session/start` and
# `/api/auth/dev-session/clear` bootstrap routes. The routes return 404
# when this flag is unset, so production / staging deployments are not
# exposed even if the routes ship in the bundle. Set to "1" in local dev
# and in the smoke harness so a developer can do
#   curl -X POST http://localhost:3000/api/auth/dev-session/start
# to mint a session cookie from the DEV_OWNER_* env above.
# ENABLE_DEV_SESSION_ROUTES=1

# Gmail OAuth. All four are required for both start and callback to leave the
# 501 "not_configured" path. GOOGLE_REDIRECT_URI may be a full URL or the magic
# value "__ORIGIN__/api/oauth/gmail/callback" for local/dev origin binding.
# OAUTH_STATE_SIGNING_SECRET signs the state cookie issued by start and
# verified by callback; rotate to invalidate in-flight grants. Min 32 chars.
# Generate with: openssl rand -base64 48
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=__ORIGIN__/api/oauth/gmail/callback
OAUTH_STATE_SIGNING_SECRET=replace-with-at-least-32-character-secret-XXXXXXXX

# Optional. Override only for tests that need to point at a local fake token
# endpoint. Defaults to https://oauth2.googleapis.com/token.
# GOOGLE_TOKEN_ENDPOINT=http://localhost:3147/token

# Google identity sign-in (P6-B). This is a SEPARATE OAuth client from the
# Gmail sender connect flow above — it asks Google for `openid email profile`
# only, never `gmail.send`. KEEPSAKE_AUTH_GOOGLE_REDIRECT_URI may be the
# magic value "__ORIGIN__/api/auth/google/callback" for local/dev origin
# binding. The state cookie reuses OAUTH_STATE_SIGNING_SECRET. Sign-in
# completion requires KEEPSAKE_DATA_SOURCE=db so we can persist the users
# row. Unset → /api/auth/google/start returns 501 not_configured.
# KEEPSAKE_AUTH_GOOGLE_CLIENT_ID=your-signin-client.apps.googleusercontent.com
# KEEPSAKE_AUTH_GOOGLE_CLIENT_SECRET=your-signin-client-secret
# KEEPSAKE_AUTH_GOOGLE_REDIRECT_URI=__ORIGIN__/api/auth/google/callback
# KEEPSAKE_AUTH_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
# KEEPSAKE_AUTH_GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
