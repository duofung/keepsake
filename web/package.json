{
  "name": "keepsake-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed:dev": "node scripts/seed-dev-fixtures.mjs",
    "test:boundaries": "node scripts/test-boundaries.mjs",
    "test:auth": "node scripts/test-auth-current-user.mjs && node scripts/test-session-route.mjs",
    "test:crypto": "node scripts/test-crypto-envelope.mjs",
    "clean:next": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "test:db": "pnpm clean:next && pnpm test:db:transaction && pnpm test:db:catalog && pnpm test:db:people && pnpm test:db:fixtures && pnpm test:db:people-route && pnpm test:db:deliveries && pnpm test:db:history-route && pnpm test:db:drafts-repository && pnpm test:db:drafts-route && pnpm clean:next",
    "test:db:transaction": "node scripts/test-db-transaction.mjs",
    "test:db:catalog": "node scripts/test-catalog-repository.mjs",
    "test:db:people": "node scripts/test-people-repository.mjs",
    "test:db:fixtures": "node scripts/test-dev-fixtures.mjs",
    "test:db:people-route": "node scripts/test-people-db-route.mjs",
    "test:db:drafts-repository": "node scripts/test-drafts-repository.mjs",
    "test:db:drafts-route": "node scripts/test-drafts-db-route.mjs",
    "test:db:deliveries": "node scripts/test-deliveries-repository.mjs",
    "test:db:history-route": "node scripts/test-history-db-route.mjs",
    "test:drafts": "node scripts/test-drafts.mjs",
    "test:people": "node scripts/test-people.mjs",
    "test:history": "node scripts/test-history.mjs",
    "test:profile": "node scripts/test-profile.mjs",
    "test": "pnpm test:boundaries && pnpm test:auth && pnpm test:people && pnpm test:drafts && pnpm test:history && pnpm test:profile"
  },
  "dependencies": {
    "next": "^15.0.3",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
